# Environment Configuration
# For production server (siaset2.webuir.com)

CI_ENVIRONMENT = production

# Base URL - Production
BASEURL = https://siaset2.webuir.com/

# Database Configuration - Production
database.default.hostname = localhost
database.default.database = siaset2_asetuir
database.default.username = siaset2_user
database.default.password = your_production_password_here

# Session
session.driver = file